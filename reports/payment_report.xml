<odoo>
    <report id="report_payment_list"
            model="gym.payment"
            string="Payment Report"
            report_type="qweb-pdf"
            name="gym_member.report_payment_list_template"
            file="gym_member.report_payment_list_template"/>
    <template id="report_payment_list_template">
        <t t-call="web.html_container">
            <div class="page">
                <div class="row">
                    <div class="col-md-12">
                        <h2>Payment Summary Report</h2>
                        <p>Generated on: <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/></p>
                        <h3>Total Revenue: <span t-esc="sum(docs.mapped('amount'))"/></h3>
                        <h4>Number of Payments: <span t-esc="len(docs)"/></h4>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Member</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="payment">
                                    <tr>
                                        <td><span t-esc="payment.payment_reference"/></td>
                                        <td><span t-esc="payment.member_name"/></td>
                                        <td><span t-esc="payment.payment_date"/></td>
                                        <td><span t-esc="payment.amount"/></td>
                                        <td><span t-esc="payment.payment_method"/></td>
                                        <td><span t-esc="payment.state"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>
    <record id="action_payment_report" model="ir.actions.act_window">
        <field name="name">Payment Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">gym.payment</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>
</odoo>