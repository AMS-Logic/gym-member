<odoo>
    <data noupdate="1">
        <record id="cron_send_expiry_notifications" model="ir.cron">
            <field name="name">Send Membership Expiry Notifications</field>
            <field name="model_id" ref="model_gym_notification"/>
            <field name="state">code</field>
            <field name="code">model.send_expiry_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        <record id="cron_deactivate_expired" model="ir.cron">
            <field name="name">Deactivate Expired Memberships</field>
            <field name="model_id" ref="model_gym_membership"/>
            <field name="state">code</field>
            <field name="code">model.deactivate_expired_memberships()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>