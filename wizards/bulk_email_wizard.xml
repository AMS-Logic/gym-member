<odoo>
    <record id="view_bulk_email_wizard" model="ir.ui.view">
        <field name="name">bulk.email.wizard.form</field>
        <field name="model">bulk.email.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Bulk Email">
                <group>
                    <field name="subject"/>
                    <field name="body" widget="html"/>
                    <field name="recipient_filter"/>
                    <field name="membership_type_filter"/>
                </group>
                <footer>
                    <button name="action_send" string="Send Email" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>