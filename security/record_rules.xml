<odoo>
    <data noupdate="1">
        <!-- Members can only see their own records -->
        <record id="rule_gym_membership_self" model="ir.rule">
            <field name="name">Gym Membership: See Own Records</field>
            <field name="model_id" ref="gym_member.model_gym_membership"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('create_uid','=',user.id)]</field>
        </record>

        <!-- Managers can see all records -->
        <record id="rule_gym_membership_manager" model="ir.rule">
            <field name="name">Gym Membership: Manager Access</field>
            <field name="model_id" ref="gym_member.model_gym_membership"/>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
    </data>
</odoo>