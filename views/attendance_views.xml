<odoo>
    <record id="view_gym_attendance_list" model="ir.ui.view">
        <field name="name">gym.attendance.list</field>
        <field name="model">gym.attendance</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_name"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="duration" sum="Total Hours"/>
                <field name="location"/>
            </list>
        </field>
    </record>
    <record id="view_gym_attendance_form" model="ir.ui.view">
        <field name="name">gym.attendance.form</field>
        <field name="model">gym.attendance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_check_out" type="object"
                                class="btn_primary"
                                string="Check Out"
                                invisible="check_out != False"/>
                    </div>
                    <group>
                        <group>
                            <field name="member_id"/>
                            <field name="member_name"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="duration"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_gym_attendance_pivot" model="ir.ui.view">
        <field name="name">gym.attendance.pivot</field>
        <field name="model">gym.attendance</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="location" type="row"/>
                <field name="member_name" type="col"/>
                <field name="duration" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_gym_attendance_graph" model="ir.ui.view">
        <field name="name">gym.attendance.graph</field>
        <field name="model">gym.attendance</field>
        <field name="arch" type="xml">
            <graph string="Attendance Trends">
                <field name="check_in" interval="month" type="row"/>
                <field name="location" type="col"/>
                <field name="duration" type="measure" operator="sum"/>
            </graph>
        </field>
    </record>
    <record id="action_gym_attendance" model="ir.actions.act_window">
        <field name="name">Attendance Logs</field>
        <field name="res_model">gym.attendance</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="help" type="html">
            <p>Track member check-ins and check-outs to monitor facility usage.</p>
        </field>
    </record>
</odoo>