<odoo>
    <record id="view_gym_class_list" model="ir.ui.view">
        <field name="name">gym.class.list</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="class_type"/>
                <field name="instructor"/>
                <field name="schedule"/>
                <field name="days_of_week"/>
                <field name="enrolled_count" widget="progressbar"/>
                <field name="available_spots"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_gym_class_form" model="ir.ui.view">
        <field name="name">gym.class.form</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button"
                                icon="fa-play-circle-o">
                            <span class="o_stat_text">Toggle Active</span>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="class_type"/>
                            <field name="instructor"/>
                            <field name="capacity"/>
                            <field name="enrolled_count"/>
                            <field name="available_spots" widget="progressbar"/>
                        </group>
                        <group>
                            <field name="schedule"/>
                            <field name="days_of_week"/>
                            <field name="start_time"/>
                            <field name="duration"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <notebook>
                        <page string="Enrolled Members">
                            <field name="member_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="membership_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_gym_class_graph" model="ir.ui.view">
        <field name="name">gym.class.graph</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <graph string="Class Enrollment">
                <field name="class_type" type="row"/>
                <field name="enrolled_count" type="measure" operator="sum"/>
                <field name="capacity" type="measure" operator="sum"/>
            </graph>
        </field>
    </record>
    <record id="action_gym_class" model="ir.actions.act_window">
        <field name="name">Gym Classes</field>
        <field name="res_model">gym.class</field>
        <field name="view_mode">list,form,graph</field>
        <field name="help" type="html">
            <p>Manage fitness classes, track enrollments, and monitor class capacity.</p>
        </field>
    </record>
</odoo>